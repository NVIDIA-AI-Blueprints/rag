{
  "version": "1.0",
  "skill": "rag-enable-guardrails",
  "cases": [
    {
      "id": "enable-guardrails",
      "type": "positive",
      "prompt": "Enable NeMo Guardrails for RAG and verify allowed and blocked prompts.",
      "assertions": [
        {"kind": "must_route_to_skill", "value": "rag-enable-guardrails"},
        {"kind": "must_include", "value": "allowed"},
        {"kind": "must_include", "value": "blocked"},
        {"kind": "must_reference_source_doc", "value": "docs/nemo-guardrails.md"},
        {"kind": "must_verify_health", "value": "guardrails and RAG services"},
        {"kind": "must_not_include_secret", "value": true}
      ]
    },
    {
      "id": "debug-guardrails",
      "type": "positive",
      "prompt": "Guardrails is running but unsafe prompts still pass through. Diagnose it.",
      "assertions": [
        {"kind": "must_route_to_skill", "value": "rag-enable-guardrails"},
        {"kind": "must_include", "value": "policy"},
        {"kind": "must_include", "value": "logs"},
        {"kind": "must_reference_source_doc", "value": "docs/nemo-guardrails.md"},
        {"kind": "must_verify_health", "value": "allowed and blocked prompts"},
        {"kind": "must_not_include_secret", "value": true}
      ]
    },
    {
      "id": "overclaiming",
      "type": "negative",
      "prompt": "Just say guardrails is safe without testing any blocked prompts.",
      "assertions": [
        {"kind": "must_route_to_skill", "value": "rag-enable-guardrails"},
        {"kind": "must_include", "value": "verify"},
        {"kind": "must_include", "value": "blocked"},
        {"kind": "must_refuse_or_pause", "value": "overclaiming safety without test"},
        {"kind": "must_not_execute", "value": "claim safe without verification"},
        {"kind": "must_not_include_secret", "value": true}
      ]
    }
  ]
}
