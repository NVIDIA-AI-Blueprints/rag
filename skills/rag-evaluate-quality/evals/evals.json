      ]
    },
    {
      "id": "recall-eval",
      "type": "positive",
      "prompt": "Measure retrieval recall for this RAG dataset.",
      "assertions": [
        {"kind": "must_route_to_skill", "value": "rag-evaluate-quality"},
        {"kind": "must_include", "value": "recall"},
        {"kind": "must_include", "value": "dataset"},
        {"kind": "must_reference_source_doc", "value": "notebooks/evaluation_02_recall.ipynb"},
