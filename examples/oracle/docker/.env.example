APP_VECTORSTORE_NAME=oracle
APP_VECTORSTORE_SEARCHTYPE=hybrid
APP_VECTORSTORE_INDEXTYPE=IVF
ORACLE_VECTOR_INDEX_TYPE=IVF
ORACLE_DISTANCE_METRIC=COSINE

# Required for self-hosted NVIDIA NIM containers:
# - Docker daemon uses this after `docker login nvcr.io -u '$oauthtoken'`
# - NIM containers use this to download model artifacts from NGC
NGC_API_KEY=
NVIDIA_API_KEY=${NGC_API_KEY}
NGC_CLI_API_KEY=${NGC_API_KEY}

# Existing-ADB mode: fill these manually.
# Create-ADB mode: provisioner writes generated/oracle.env with these values.
ORACLE_USER=RAG_APP
ORACLE_PASSWORD=
ORACLE_CS=
